# ============================================================
#  TourneyEdge AI — Environment Variables
#  Copy this file to .env.local and fill in your values.
#  NEVER commit .env.local to GitHub.
# ============================================================

# ------------------------------------------------------------
# KENPOM
# Sign up at https://kenpom.com — subscribe for API access.
# Used for: adjusted efficiency, tempo, luck, SOS metrics.
# ------------------------------------------------------------
KENPOM_EMAIL=your_kenpom_email@example.com
KENPOM_PASSWORD=your_kenpom_password

# ------------------------------------------------------------
# THE ODDS API  (Recommended — easiest betting lines source)
# Sign up at https://the-odds-api.com (free tier: 500 req/month)
# Used for: spread, moneyline, over/under from 40+ sportsbooks.
# ------------------------------------------------------------
ODDS_API_KEY=your_odds_api_key_here

# Which sportsbook to prefer when multiple are available.
# Options: draftkings | fanduel | betmgm | caesars | pointsbet
ODDS_API_BOOK=draftkings

# Sport key for NCAA basketball
ODDS_API_SPORT=basketball_ncaab

# ------------------------------------------------------------
# ESPN / COLLEGE BASKETBALL REFERENCE
# ESPN has a public (unofficial) API — no key required for basic
# stats. Set USE_ESPN_PUBLIC=true to enable it.
# For production, use a licensed stats provider instead.
# ------------------------------------------------------------
USE_ESPN_PUBLIC=true

# Optional: RapidAPI key if using a hosted ESPN stats wrapper
# Sign up at https://rapidapi.com and subscribe to "NCAA Basketball"
RAPIDAPI_KEY=your_rapidapi_key_here
RAPIDAPI_HOST=ncaa-basketball.p.rapidapi.com

# ------------------------------------------------------------
# SPORTRADAR (Premium — most reliable team stats + play-by-play)
# Sign up at https://developer.sportradar.com
# Used for: full team stats, schedules, rosters, injuries.
# ------------------------------------------------------------
SPORTRADAR_API_KEY=your_sportradar_key_here

# ------------------------------------------------------------
# OPENAI (optional — for AI narrative generation)
# Used for: plain-English explanations of model picks.
# The rules-based model works without this.
# Sign up at https://platform.openai.com
# ------------------------------------------------------------
OPENAI_API_KEY=your_openai_key_here
OPENAI_MODEL=gpt-4o-mini

# ------------------------------------------------------------
# REDIS (optional — for caching API responses)
# Prevents hitting rate limits on paid APIs.
# Use Upstash for a free Redis instance on Vercel:
# https://upstash.com
# ------------------------------------------------------------
REDIS_URL=redis://localhost:6379
# For Upstash:
# UPSTASH_REDIS_REST_URL=https://your-instance.upstash.io
# UPSTASH_REDIS_REST_TOKEN=your_token_here

# Cache TTL in seconds (300 = 5 minutes)
CACHE_TTL_SECONDS=300

# ------------------------------------------------------------
# APP CONFIG
# ------------------------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Set to 'mock' to use seed data, 'live' to use real APIs
DATA_MODE=mock
